unique_words <- function(text) {
words <- str_to_lower(str_extract_all(text, "\\b\\w+\\b")[[1]])  # lowercase
length(unique(words))
}
# apply to all documents
doc_vocab_counts <- sapply(all_texts, unique_words)
# apply to all documents
doc_vocab_counts <- sapply(all_texts, unique_words)
# preview top 5
head(df_texts)
df_texts <- data.frame(
text = all_texts,
word_count = doc_word_counts,
vocab_count = doc_vocab_counts,
stringsAsFactors = FALSE
)
# load libraries
#install.packages("manifestoR")
library(manifestoR)
library(dplyr)
library(stringr)
# set api key - reminder to self to later add this file to the gitignore before pushing
mp_setapikey("manifesto_apikey.txt")
# get the dataset
mpds <- mp_maindataset()
# look at names
names(mpds)
# check to see what the dataset looks like
mpds
mp_availability(TRUE)
all <- mp_availability(TRUE)
all_docs <- mp_corpus(all)
english_only <- mp_availability(TRUE) %>%
filter(language == "english")
english_docs <- mp_corpus(english_only)
length(english_docs)
class(all_docs)
typeof(all_docs)
length(all_docs)
all_docs[[1]]
content(all_docs[[1]])
all_texts <- sapply(all_docs, content)
# count word count in all documents
doc_word_counts <- str_count(all_texts, boundary("word"))
# mean word count in all
mean(doc_word_counts)
# median word count in all
median(doc_word_counts)
# word count in the longest document
max(doc_word_counts)
# min word count
min(doc_word_counts)
# how many unique countries? 67 countries
mpds %>%
select(countryname) %>%
unique() %>%
nrow()
mpds %>%
select(parfam) %>%
unique() %>%
nrow()
mpds %>%
group_by(parfam) %>%
summarize(count=n()) %>%
arrange(desc(count))
total_n <- nrow(mpds)
mpds %>%
group_by(countryname) %>%
summarize(
count = n(),
pct_of_total = 100 * (count / total_n)
) %>%
arrange(desc(count))
summary(mpds$edate)
mpds %>%
arrange((edate))
mpds %>%
arrange(desc(edate))
write_csv(all_docs, "all_docs.csv")
