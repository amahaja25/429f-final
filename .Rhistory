library(dplyr)
library(purrr)
library(tibble)
all_docs_df <- tibble(
doc_id = seq_along(all_docs),
text = map_chr(all_docs, ~ {
txt <- .x$content$text
if (is.null(txt) || length(txt) == 0) return(NA_character_)
as.character(txt)
}),
party = map_chr(all_docs, ~ as.character(.x$meta$party)),
date = map_chr(all_docs, ~ as.character(.x$meta$date)),
manifesto_id = map_chr(all_docs, ~ .x$meta$manifesto_id),
language = map_chr(all_docs, ~ .x$meta$language)
)
all_docs_df <- tibble(
doc_id = seq_along(all_docs),
text = map_chr(all_docs, ~ {
txt <- .x$content$text
if (is.null(txt) || length(txt) == 0) return(NA_character_)
paste(as.character(txt), collapse = " ")  # collapse vector → single string
}),
party = map_chr(all_docs, ~ as.character(.x$meta$party)),
date  = map_chr(all_docs, ~ as.character(.x$meta$date)),
manifesto_id = map_chr(all_docs, ~ .x$meta$manifesto_id),
language = map_chr(all_docs, ~ .x$meta$language)
)
# Check the structure of the first few docs
str(all_docs[[1]], max.level = 2)
str(all_docs[[2]], max.level = 2)
# See what content looks like across docs
map(all_docs[1:10], ~ names(.x$content))
# Find which docs are returning length != 1 after your map
text_lengths <- map_int(all_docs, ~ {
txt <- .x$content$text
if (is.null(txt) || length(txt) == 0) return(0L)
length(as.character(txt))
})
table(text_lengths)  # see the distribution
which(text_lengths != 1)[1:10]  # find the first offenders
# First check — how many actual docs with text exist?
length(all_docs)  # total slots
sum(map_lgl(all_docs, ~ !is.null(.x$content$text)))  # docs with text
# The fix: use as.list() to properly flatten the corpus,
# then filter to only docs that actually have text
all_docs_df <- keep(as.list(all_docs), ~ !is.null(.x$content)) |>
map_dfr(~ {
txt <- .x$content$text
tibble(
text         = if (is.null(txt) || length(txt) == 0) NA_character_
else paste(txt, collapse = " "),
party        = as.character(.x$meta$party),
date         = as.character(.x$meta$date),
manifesto_id = as.character(.x$meta$manifesto_id),
language     = as.character(.x$meta$language)
)
})
nrow(all_docs_df)
# Test on a single document first
doc1 <- all_docs[[1]]
class(doc1)
str(doc1, max.level = 1)
# manifestoR documents are accessed like this:
doc1$content        # should show the dataframe
doc1$content$text   # should show text
doc1$content$text
doc1$content
doc1$content$text   # should show text
all_docs_list <- lapply(seq_along(all_docs), function(i) all_docs[[i]])
sum(sapply(all_docs_list, function(x) !is.null(x$content$text)))
all_docs_df <- map_dfr(all_docs_list, ~ {
txt <- .x$content$text
tibble(
text         = if (is.null(txt) || length(txt) == 0) NA_character_
else paste(txt, collapse = " "),
party        = as.character(.x$meta$party),
date         = as.character(.x$meta$date),
manifesto_id = as.character(.x$meta$manifesto_id),
language     = as.character(.x$meta$language)
)
})
nrow(all_docs_df)
write.csv(all_docs_df, "manifesto_texts.csv",
row.names = FALSE, fileEncoding = "UTF-8")
